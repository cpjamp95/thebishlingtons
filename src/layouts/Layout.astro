---
type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "The wedding website for Cameron and Alex.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>